# Hyperliquid Copy Trading Bot — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Discord bot token (from discord.com/developers)
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord webhook URL (for notifications)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Follower wallet address (your wallet that copies trades)
HL_PAIR_0_FOLLOWER_ADDRESS=0xyour_wallet_address

# Agent wallet private key (only needed for live mode)
# HL_PAIR_0_AGENT_PRIVATE_KEY=your_agent_key
